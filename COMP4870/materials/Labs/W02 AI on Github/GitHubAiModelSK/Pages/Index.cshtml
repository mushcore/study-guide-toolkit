@page
@model IndexModel
@{
    ViewData["Title"] = "AI Chat";
}

<div class="container">
    <h1 class="display-4 text-center">AI Chat</h1>
    <p class="text-center text-muted">Powered by Semantic Kernel &amp; GitHub AI Models</p>

    <div class="card mt-4">
        <div class="card-body" style="height: 400px; overflow-y: auto;" id="chatBox">
            @if (Model.ChatMessages.Count == 0)
            {
                <p class="text-muted text-center mt-5">Ask a question to start chatting!</p>
            }
            @foreach (var msg in Model.ChatMessages)
            {
                <div class="mb-3">
                    <strong class="@(msg.Role == "User" ? "text-primary" : "text-success")">
                        @(msg.Role == "User" ? "You" : "Assistant"):
                    </strong>
                    <span>@msg.Message</span>
                </div>
            }
        </div>
    </div>

    <form method="post" class="mt-3">
        <div class="input-group">
            <input type="text" asp-for="UserMessage" class="form-control"
                   placeholder="Type your question here..." autocomplete="off" />
            <button type="submit" class="btn btn-primary">Send</button>
        </div>
    </form>
</div>
