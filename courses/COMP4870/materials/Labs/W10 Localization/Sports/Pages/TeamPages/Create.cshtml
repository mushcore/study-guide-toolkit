@page
@model Sports.Pages.TeamPages.CreateModel
@inject Sports.Services.SharedResourceService sharedLocalizer

@{
    ViewData["Title"] = @sharedLocalizer.Get("Create");
}

<h1>@sharedLocalizer.Get("Create")</h1>

<h4>@sharedLocalizer.Get("Team")</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Team.TeamName" class="control-label"></label>
                <input asp-for="Team.TeamName" class="form-control" />
                <span asp-validation-for="Team.TeamName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Team.City" class="control-label"></label>
                <input asp-for="Team.City" class="form-control" />
                <span asp-validation-for="Team.City" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="@sharedLocalizer.Get("Create")" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">@sharedLocalizer.Get("BackToList")</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
